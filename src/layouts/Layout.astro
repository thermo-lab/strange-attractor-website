---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Strange Attractor Prints" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-950 text-gray-100 min-h-screen relative selection:bg-blue-500 selection:text-white">
		
        <div class="fixed inset-0 -z-10 h-full w-full bg-gray-950 [background:radial-gradient(125%_125%_at_50%_10%,#000_40%,#1e1b4b_100%)]"></div>
		
        <nav class="fixed top-0 w-full z-50 backdrop-blur-md border-b border-white/10">
            <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
                <a href="https://www.strangeattractor.xyz" class="font-bold text-xl tracking-tighter">STRANGE<span class="text-indigo-500">ATTRACTOR</span></a>
                <div class="flex gap-6 text-sm font-medium text-gray-400">
                    <a href="https://vis.strangeattractor.xyz" class="hover:text-white transition-colors">Create</a>
                    <!--<a href="#gallery" class="hover:text-white transition-colors">Prints</a>-->
<a 
      href="https://x.com/strangeattxyz" 
      target="_blank" 
      rel="noopener noreferrer"
      class="text-gray-400 hover:text-white transition-colors"
      aria-label="X (formerly Twitter)"
    >
      <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
                </div>
            </div>
        </nav>

		<slot />
	</body>
</html>
